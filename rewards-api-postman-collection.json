            },
            "description": "Returns reward summaries for ALL customers over the last 3 months."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array of customers', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.be.an('array');",
                  "  pm.expect(body.length).to.be.greaterThan(0);",
                  "});",
                  "pm.test('Each entry has totalRewardPoints', () => {",
                  "  pm.response.json().forEach(r => {",
                  "    pm.expect(r.totalRewardPoints).to.be.a('number');",
                  "  });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
