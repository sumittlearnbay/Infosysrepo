    {
      "name": "❌ Error Scenarios",
      "item": [
        {
          "name": "404 – Customer Not Found",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/rewards/INVALID_CUSTOMER",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "rewards", "INVALID_CUSTOMER"]
            },
            "description": "Should return 404 with error body for an unknown customer ID."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));",
                  "pm.test('Error body has correct shape', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql(404);",
                  "  pm.expect(body.error).to.eql('Not Found');",
                  "  pm.expect(body.message).to.exist;",
                  "  pm.expect(body.timestamp).to.exist;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "400 – months=0 (out of range)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/rewards/C001?months=0",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "rewards", "C001"],
              "query": [{"key": "months", "value": "0"}]
            },
            "description": "months must be between 1 and 36. Expects 400."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Error body has status 400', () => {",
                  "  pm.expect(pm.response.json().status).to.eql(400);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "400 – months=37 (too large)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/rewards/C001?months=37",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "rewards", "C001"],
              "query": [{"key": "months", "value": "37"}]
            },
            "description": "months exceeds max of 36. Expects 400."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "400 – months=abc (type mismatch)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/rewards/C001?months=abc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "rewards", "C001"],
              "query": [{"key": "months", "value": "abc"}]
            },
            "description": "Non-numeric months parameter. Expects 400."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "400 – Date Range: missing startDate",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/rewards/C001/range?endDate=2024-12-31",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "rewards", "C001", "range"],
              "query": [{"key": "endDate", "value": "2024-12-31"}]
            },
            "description": "startDate is required. Expects 400."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Missing param error message', () => {",
                  "  pm.expect(pm.response.json().message).to.include('startDate');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "400 – Date Range: end before start",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/rewards/C001/range?startDate=2024-06-01&endDate=2024-01-01",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "rewards", "C001", "range"],
              "query": [
                {"key": "startDate", "value": "2024-06-01"},
                {"key": "endDate",   "value": "2024-01-01"}
              ]
            },
            "description": "endDate is before startDate. Expects 400."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "400 – Date Range: future startDate",
          "request": {
            "method": "GET",
